rules_version = '2';

// ════════════════════════════════════════════════════════════════════════
// CANONICAL FIRESTORE RULESET — SINGLE SOURCE OF TRUTH
//
// Firebase project: pokerhq-a67e4 (default database, shared by 3 apps:
// PokerHQ, Bob's Daily Briefing, SonicVault). A shared database has ONE
// ruleset, so any `firebase deploy --only firestore:rules` REPLACES the
// rules for every app at once — a PokerHQ-only deploy on 2026-06-11 locked
// SonicVault and Daily Briefer out.
//
// FIX (2026-06-22): rule ownership is now CENTRALIZED in this repo. Rules
// are no longer copied across three repos.
//   • THIS file (sonicvault/firestore.rules) is the ONLY place rules are
//     edited, and this is the ONLY repo that deploys them.
//     Deploy with: ./deploy-rules.ps1  (or firebase deploy --only firestore:rules)
//   • The pokerhq and bobdailybriefing repos MUST NOT deploy Firestore rules.
//     Remove the "firestore" block from their firebase.json so a stray
//     `firebase deploy` there cannot touch rules. Any rules file still sitting
//     in those repos is stale/reference-only — do not deploy it.
//   • When ANY app's rules change (PokerHQ or Daily Briefer included), edit
//     them HERE and deploy from HERE.
// ════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isBobGoogleAccount() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
          'bobbynacario@gmail.com'
        ];
    }

    function isSonicVaultOwner() {
      return (request.auth != null && request.auth.token.sonicvaultOwner == true)
        || isBobGoogleAccount();
    }

    // ─────────────────────────────────────────────────────────────
    // PokerHQ — owner-locked, requires verified Google email
    // ─────────────────────────────────────────────────────────────
    match /pokerhq-bob/{docId} {
      allow read, write: if isBobGoogleAccount()
        && request.auth.token.email_verified == true;
    }
    match /{collection}/{docId} {
      allow read, write: if isBobGoogleAccount()
        && request.auth.token.email_verified == true
        && collection.matches('pokerhq-profile-.*');
    }

    // ─────────────────────────────────────────────────────────────
    // Bob's Daily Briefing — authenticated, uid-scoped
    // ─────────────────────────────────────────────────────────────
    match /briefings-bob/{docId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || !('uid' in resource.data));

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;

      allow update: if request.auth != null
        && (resource.data.uid == request.auth.uid || !('uid' in resource.data))
        && request.resource.data.uid == request.auth.uid;

      allow delete: if request.auth != null
        && (resource.data.uid == request.auth.uid || !('uid' in resource.data));
    }

    // ─────────────────────────────────────────────────────────────
    // Bob's Daily Briefing — deep-research reports, uid-scoped
    // ─────────────────────────────────────────────────────────────
    match /reports-bob/{docId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || !('uid' in resource.data));

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;

      allow update: if request.auth != null
        && (resource.data.uid == request.auth.uid || !('uid' in resource.data))
        && request.resource.data.uid == request.auth.uid;

      allow delete: if request.auth != null
        && (resource.data.uid == request.auth.uid || !('uid' in resource.data));
    }

    // Bob's Daily Briefing — decision journal, uid-scoped
    match /journal-bob/{docId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;

      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────────────
    // SonicVault — private vault locked to owner; public share
    // catalogs are world-readable but owner-writable only.
    // The watcher uses the Admin SDK and bypasses these rules.
    // ─────────────────────────────────────────────────────────────
    match /sonicvault-bob/{docId} {
      allow read, write, delete: if isSonicVaultOwner();
    }
    match /sonicvault-public-tracks/{docId} {
      allow read: if true;
      allow create, update, delete: if isSonicVaultOwner();
    }
    match /sonicvault-public-playlists/{docId} {
      allow read: if true;
      allow create, update, delete: if isSonicVaultOwner();
    }

    // ─────────────────────────────────────────────────────────────
    // Deny everything else (any unknown collection)
    // ─────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
